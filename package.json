{
  "name": "clash-vscode-yosys",
  "displayName": "Clash Verilog Yosys Extension",
  "description": "Synthesize Verilog from monomorphic Haskell functions using Clash and Yosys",
  "version": "0.0.1",
  "publisher": "clash-lang",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/clash-vscode-yosys"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "clash",
    "haskell",
    "fpga",
    "verilog",
    "yosys",
    "hardware"
  ],
  "activationEvents": [
    "onLanguage:haskell"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "clash-synthesis",
          "title": "Clash Synthesis",
          "icon": "resources/clash-icon.svg"
        }
      ]
    },
    "views": {
      "clash-synthesis": [
        {
          "id": "clash-vscode-yosys.haskellFunctions",
          "name": "Haskell Functions"
        },
        {
          "id": "clash-vscode-yosys.synthesisResults",
          "name": "Synthesis Results"
        }
      ]
    },
    "commands": [
      {
        "command": "clash-vscode-yosys.detectFunctions",
        "title": "Clash: Detect Functions"
      },
      {
        "command": "clash-vscode-yosys.synthesizeFunction",
        "title": "Clash: Generate Verilog",
        "icon": "$(file-code)"
      },
      {
        "command": "clash-vscode-yosys.synthesizeOnly",
        "title": "Clash: Synthesize",
        "icon": "$(circuit-board)"
      },
      {
        "command": "clash-vscode-yosys.synthesizeAndPnR",
        "title": "Clash: Synthesize and Place & Route",
        "icon": "$(layers)"
      },
      {
        "command": "clash-vscode-yosys.checkToolchain",
        "title": "Clash: Check Toolchain"
      },
      {
        "command": "clash-vscode-yosys.openResultsPanel",
        "title": "Clash: Open Synthesis Results Panel",
        "icon": "$(open-preview)"
      },
      {
        "command": "clash-vscode-yosys.refreshHaskellFunctions",
        "title": "Clash: Refresh Haskell Functions",
        "icon": "$(refresh)"
      },
      {
        "command": "clash-vscode-yosys.viewModuleDiagram",
        "title": "Clash: View Module Diagram",
        "icon": "$(open-preview)"
      },
      {
        "command": "clash-vscode-yosys.goToFunction",
        "title": "Clash: Go To Function"
      },
      {
        "command": "clash-vscode-yosys.openSynthesizedVerilog",
        "title": "Clash: Open Synthesized Verilog",
        "icon": "$(file-code)"
      },
      {
        "command": "clash-vscode-yosys.openSettings",
        "title": "Clash: Open Settings",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "clash-vscode-yosys.synthesizeFunction",
          "when": "view == clash-vscode-yosys.haskellFunctions",
          "group": "navigation@1"
        },
        {
          "command": "clash-vscode-yosys.synthesizeOnly",
          "when": "view == clash-vscode-yosys.haskellFunctions",
          "group": "navigation@2"
        },
        {
          "command": "clash-vscode-yosys.synthesizeAndPnR",
          "when": "view == clash-vscode-yosys.haskellFunctions",
          "group": "navigation@3"
        },
        {
          "command": "clash-vscode-yosys.refreshHaskellFunctions",
          "when": "view == clash-vscode-yosys.haskellFunctions",
          "group": "navigation@4"
        },
        {
          "command": "clash-vscode-yosys.openSettings",
          "when": "view == clash-vscode-yosys.haskellFunctions",
          "group": "navigation@5"
        },
        {
          "command": "clash-vscode-yosys.openResultsPanel",
          "when": "view == clash-vscode-yosys.synthesisResults",
          "group": "navigation@1"
        },
        {
          "command": "clash-vscode-yosys.openSettings",
          "when": "view == clash-vscode-yosys.synthesisResults",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "clash-vscode-yosys.openSynthesizedVerilog",
          "when": "view == clash-vscode-yosys.synthesisResults && viewItem =~ /verilog/",
          "group": "inline@1"
        },
        {
          "command": "clash-vscode-yosys.viewModuleDiagram",
          "when": "view == clash-vscode-yosys.synthesisResults && viewItem =~ /diagram/",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "Clash Verilog Yosys",
      "properties": {
        "clash-vscode-yosys.yosysCommand": {
          "type": "string",
          "default": "yosys",
          "description": "Command to run Yosys"
        },
        "clash-vscode-yosys.outputFormat": {
          "type": "string",
          "enum": [
            "verilog",
            "vhdl",
            "systemverilog"
          ],
          "default": "verilog",
          "description": "HDL output format for Clash"
        },
        "clash-vscode-yosys.autoCleanup": {
          "type": "boolean",
          "default": false,
          "description": "Automatically cleanup temporary synthesis files"
        },
        "clash-vscode-yosys.showYosysSchematic": {
          "type": "boolean",
          "default": false,
          "description": "Show schematic visualization after Yosys synthesis"
        },
        "clash-vscode-yosys.synthesisMode": {
          "type": "string",
          "enum": [
            "whole-design",
            "per-module"
          ],
          "default": "per-module",
          "description": "Synthesis mode: whole-design synthesizes everything at once; per-module synthesizes each component separately with individual diagrams"
        },
        "clash-vscode-yosys.synthesisTarget": {
          "type": "string",
          "enum": [
            "generic",
            "ice40",
            "ecp5",
            "xilinx",
            "gowin",
            "intel",
            "quicklogic",
            "sf2"
          ],
          "enumDescriptions": [
            "Generic (technology-independent synthesis)",
            "Lattice iCE40 (synth_ice40)",
            "Lattice ECP5 (synth_ecp5)",
            "AMD / Xilinx 7-series (synth_xilinx)",
            "Gowin (synth_gowin)",
            "Intel / Altera (synth_intel)",
            "QuickLogic (synth_quicklogic)",
            "Microsemi SmartFusion2 (synth_sf2)"
          ],
          "default": "generic",
          "description": "Target FPGA family for Yosys synthesis"
        },
        "clash-vscode-yosys.synthesisScript.generic": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for Generic target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-vscode-yosys.synthesisScript.ice40": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for iCE40 target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-vscode-yosys.synthesisScript.ecp5": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for ECP5 target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-vscode-yosys.synthesisScript.xilinx": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for Xilinx target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-vscode-yosys.synthesisScript.gowin": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for Gowin target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-vscode-yosys.synthesisScript.intel": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for Intel target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-vscode-yosys.synthesisScript.quicklogic": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for QuickLogic target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-vscode-yosys.synthesisScript.sf2": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for SmartFusion2 target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "VSCODE_EXECUTABLE_PATH=${VSCODE_EXECUTABLE_PATH:-code} node ./out/test/runTest.js",
    "test:unit": "echo 'Unit tests require running in VS Code test environment. Use F5 with Extension Tests configuration.'"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.4.0",
    "eslint": "^9.0.0",
    "glob": "^10.5.0",
    "mocha": "^10.8.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "digitaljs": "^0.14.2",
    "vscode-languageclient": "^9.0.1",
    "yosys2digitaljs": "^0.10.3"
  }
}
