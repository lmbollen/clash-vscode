{
  "name": "clash-toolkit",
  "displayName": "Clash Toolkit",
  "description": "Community extension for Clash: synthesize, view schematics, and place-and-route Haskell hardware designs with Yosys and nextpnr.",
  "version": "0.1.0",
  "license": "BSD-2-Clause",
  "publisher": "lmbollen",
  "icon": "resources/clash-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/lmbollen/clash-toolkit"
  },
  "bugs": {
    "url": "https://github.com/lmbollen/clash-toolkit/issues"
  },
  "homepage": "https://github.com/lmbollen/clash-toolkit#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "clash",
    "haskell",
    "fpga",
    "verilog",
    "yosys",
    "hardware"
  ],
  "activationEvents": [
    "onLanguage:haskell"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "clash-synthesis",
          "title": "Clash Synthesis",
          "icon": "resources/clash-icon.svg"
        }
      ]
    },
    "views": {
      "clash-synthesis": [
        {
          "id": "clash-toolkit.haskellFunctions",
          "name": "Haskell Functions"
        },
        {
          "id": "clash-toolkit.synthesisResults",
          "name": "Synthesis Results"
        }
      ]
    },
    "commands": [
      {
        "command": "clash-toolkit.detectFunctions",
        "title": "Clash: Detect Functions"
      },
      {
        "command": "clash-toolkit.synthesizeFunction",
        "title": "Clash: Generate Verilog",
        "icon": "$(file-code)"
      },
      {
        "command": "clash-toolkit.elaborate",
        "title": "Clash: Elaborate",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "clash-toolkit.synthesize",
        "title": "Clash: Synthesize",
        "icon": "$(circuit-board)"
      },
      {
        "command": "clash-toolkit.placeAndRoute",
        "title": "Clash: Place & Route",
        "icon": "$(layers)"
      },
      {
        "command": "clash-toolkit.checkToolchain",
        "title": "Clash: Check Toolchain"
      },
      {
        "command": "clash-toolkit.openResultsPanel",
        "title": "Clash: Open Synthesis Results Panel",
        "icon": "$(open-preview)"
      },
      {
        "command": "clash-toolkit.refreshHaskellFunctions",
        "title": "Clash: Refresh Haskell Functions",
        "icon": "$(refresh)"
      },
      {
        "command": "clash-toolkit.viewModuleDiagram",
        "title": "Clash: View Module Diagram",
        "icon": "$(open-preview)"
      },
      {
        "command": "clash-toolkit.goToFunction",
        "title": "Clash: Go To Function"
      },
      {
        "command": "clash-toolkit.openSynthesizedVerilog",
        "title": "Clash: Open Synthesized Verilog",
        "icon": "$(file-code)"
      },
      {
        "command": "clash-toolkit.openSettings",
        "title": "Clash: Open Settings",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "clash-toolkit.synthesizeFunction",
          "when": "view == clash-toolkit.haskellFunctions",
          "group": "navigation@1"
        },
        {
          "command": "clash-toolkit.elaborate",
          "when": "view == clash-toolkit.haskellFunctions",
          "group": "navigation@2"
        },
        {
          "command": "clash-toolkit.synthesize",
          "when": "view == clash-toolkit.haskellFunctions",
          "group": "navigation@3"
        },
        {
          "command": "clash-toolkit.placeAndRoute",
          "when": "view == clash-toolkit.haskellFunctions",
          "group": "navigation@4"
        },
        {
          "command": "clash-toolkit.refreshHaskellFunctions",
          "when": "view == clash-toolkit.haskellFunctions",
          "group": "navigation@5"
        },
        {
          "command": "clash-toolkit.openSettings",
          "when": "view == clash-toolkit.haskellFunctions",
          "group": "navigation@6"
        },
        {
          "command": "clash-toolkit.openResultsPanel",
          "when": "view == clash-toolkit.synthesisResults",
          "group": "navigation@1"
        },
        {
          "command": "clash-toolkit.openSettings",
          "when": "view == clash-toolkit.synthesisResults",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "clash-toolkit.openSynthesizedVerilog",
          "when": "view == clash-toolkit.synthesisResults && viewItem =~ /verilog/",
          "group": "inline@1"
        },
        {
          "command": "clash-toolkit.viewModuleDiagram",
          "when": "view == clash-toolkit.synthesisResults && viewItem =~ /diagram/",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "Clash Toolkit",
      "properties": {
        "clash-toolkit.yosysCommand": {
          "type": "string",
          "default": "yosys",
          "description": "Command to run Yosys"
        },
        "clash-toolkit.outputFormat": {
          "type": "string",
          "enum": [
            "verilog",
            "vhdl",
            "systemverilog"
          ],
          "default": "verilog",
          "description": "HDL output format for Clash"
        },
        "clash-toolkit.autoCleanup": {
          "type": "boolean",
          "default": false,
          "description": "Automatically cleanup temporary synthesis files"
        },
        "clash-toolkit.showYosysSchematic": {
          "type": "boolean",
          "default": false,
          "description": "Show schematic visualization after Yosys synthesis"
        },
        "clash-toolkit.synthesisMode": {
          "type": "string",
          "enum": [
            "whole-design",
            "per-module"
          ],
          "default": "per-module",
          "description": "Synthesis mode: whole-design synthesizes everything at once; per-module synthesizes each component separately with individual diagrams"
        },
        "clash-toolkit.pnrTargetFrequencyMHz": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "description": "Target frequency in MHz passed to nextpnr as --freq. Used when no SDC file is present; with an SDC, the SDC constraint takes precedence. Leave blank to let nextpnr report Fmax without a target."
        },
        "clash-toolkit.pnrWriteRoutedSvg": {
          "type": "boolean",
          "default": true,
          "description": "Write a routed-layout SVG alongside the nextpnr output — useful for visualising where the design landed on the fabric."
        },
        "clash-toolkit.synthesisTarget": {
          "type": "string",
          "enum": [
            "generic",
            "ice40",
            "ecp5",
            "xilinx",
            "gowin",
            "intel",
            "quicklogic",
            "sf2"
          ],
          "enumDescriptions": [
            "Generic (technology-independent synthesis)",
            "Lattice iCE40 (synth_ice40)",
            "Lattice ECP5 (synth_ecp5)",
            "AMD / Xilinx 7-series (synth_xilinx)",
            "Gowin (synth_gowin)",
            "Intel / Altera (synth_intel)",
            "QuickLogic (synth_quicklogic)",
            "Microsemi SmartFusion2 (synth_sf2)"
          ],
          "default": "generic",
          "description": "Target FPGA family for Yosys synthesis"
        },
        "clash-toolkit.elaborationScript": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for the Elaboration stage (hierarchy + proc, no technology mapping). Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-toolkit.synthesisScript.generic": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for Generic target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-toolkit.synthesisScript.ice40": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for iCE40 target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-toolkit.synthesisScript.ecp5": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for ECP5 target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-toolkit.synthesisScript.xilinx": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for Xilinx target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-toolkit.synthesisScript.gowin": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for Gowin target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-toolkit.synthesisScript.intel": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for Intel target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-toolkit.synthesisScript.quicklogic": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for QuickLogic target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        },
        "clash-toolkit.synthesisScript.sf2": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom Yosys script for SmartFusion2 target. Leave empty to use the built-in default. Placeholders: {files}, {topModule}, {outputDir}, {outputBaseName}"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "clean": "rm -rf out",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run clean && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "VSCODE_EXECUTABLE_PATH=${VSCODE_EXECUTABLE_PATH:-code} node ./out/test/runTest.js",
    "test:unit": "echo 'Unit tests require running in VS Code test environment. Use F5 with Extension Tests configuration.'",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^9.0.0",
    "glob": "^10.5.0",
    "mocha": "^10.8.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "digitaljs": "^0.14.2",
    "vscode-languageclient": "^9.0.1",
    "yosys2digitaljs": "^0.10.3"
  }
}
